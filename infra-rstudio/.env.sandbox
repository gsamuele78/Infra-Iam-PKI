# Sandbox .env for infra-rstudio (runs on 192.168.56.40 conceptually in Vagrant, or host network testing)
# Integrated with iam-host (192.168.56.20) and pki-host (192.168.56.10)

AUTH_BACKEND=sssd

HOST_DOMAIN=192.168.56.40
HTTPS_PORT=8443
RSTUDIO_PORT=8787

RSTUDIO_MEMORY_LIMIT=2G
RSTUDIO_CPU_LIMIT=1.0
RAMDISK_SIZE=1G
DOCKER_USERID=1000
DOCKER_GROUPID=1000

# Step-CA Root
STEP_CA_ROOT_PATH=../infra-rstudio/shared-certs/step-ca-root.crt

# AI Engines limits
OLLAMA_RAM_LIMIT=2G
OLLAMA_CPU_LIMIT=1.0

# OIDC Zero Trust Details for sidecar
OIDC_ENDPOINT=http://192.168.56.20/realms/master/.well-known/openid-configuration
OIDC_CLIENT_ID=rstudio
OIDC_CLIENT_SECRET=sandbox_rstudio_secret
