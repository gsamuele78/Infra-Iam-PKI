# .env.example for infra-pki
# Copy this file to .env and replace the placeholder values with your actual configuration.

# System user and group IDs for container process binding
PUID=1000
PGID=1000

# Domain configuration
DOMAIN_CA=ca.example.com
PKI_NAME="Internal Root CA"
PKI_ADMIN_SUBJECT="step" 

# Optional overriding of DNS names for the CA
# PKI_DNS_NAMES="localhost,ca.example.com,step-ca"

# Master password for the CA (Make sure to generate a strong random password in production)
CA_PASSWORD=change_me_ca_password_example

# Database Configuration
POSTGRES_DB=step_ca_db
POSTGRES_USER=step_ca_user
POSTGRES_PASSWORD=step_ca_password_change_me

# Caddy Security - Define allowed IP ranges to access the endpoints
ALLOWED_IPS="127.0.0.1/32 192.168.0.0/16 172.16.0.0/12 10.0.0.0/8 172.18.0.0/16"

# Provisioner Configuration
ENABLE_ACME=true
ENABLE_SSH_PROVISIONER=true
SSH_HOST_PROVISIONER_PASSWORD=change_me_ssh_host_password

# OIDC Configuration (Uncomment and fill to enable)
# OIDC_NAME=Google
# OIDC_CLIENT_ID=your_client_id
# OIDC_CLIENT_SECRET=your_client_secret
# OIDC_ENDPOINT=https://accounts.google.com/.well-known/openid-configuration
# OIDC_DOMAIN=example.com

# Kubernetes Provisioner (Future Support)
# Enable this and mount the K8s SA public key to /home/step/secrets/k8s_sa_pub.pem
# ENABLE_K8S_PROVISIONER=false
