# Sandbox .env for infra-ood (ood-host: 192.168.56.30)
# Points OIDC to the iam-host and the PKI root CA to pki-host.

OIDC_ENDPOINT=http://192.168.56.20/realms/master/.well-known/openid-configuration
OIDC_CLIENT_ID=ondemand
OIDC_CLIENT_SECRET=sandbox_ood_secret

# PKI — for trusting the CA certificate via init container
CA_URL=https://192.168.56.10:9000
FINGERPRINT=
