# .env.example for infra-iam
# Copy this file to .env and replace the placeholder values with your actual configuration.

# System user and group IDs for container process binding
PUID="1000"
PGID="1000"

# Domains for SSO and CA, used to configure Caddy and Keycloak
DOMAIN_SSO="sso.example.com"
DOMAIN_CA="ca.example.com"
IP_CA="192.168.1.10"

# Secrets (Make sure to generate strong random passwords in production)
DB_PASSWORD="change_me_db_password_example"
KC_ADMIN_PASSWORD="change_me_admin_password_example"

# PKI Configuration (Point to the internal CA for trusting certificates)
CA_URL="https://ca.biome.unibo.it:9000"
# Leave FINGERPRINT empty initially, it will be automatically fetched if empty, or provide the actual fingerprint.
FINGERPRINT=""

# Active Directory Configuration
AD_HOST="ad.biome.unibo.it"
AD_PORT="636"
# Leave AD_FINGERPRINT empty initially, it should be populated with the AD server's certificate fingerprint
AD_FINGERPRINT=""
